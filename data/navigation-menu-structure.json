  "seo_optimization": {
    "link_structure": {
      "home_click_distance": 1,
      "category_click_distance": 1,
      "tag_click_distance": 2,
      "description": "Homepage → any category ≤1 click (R7 requirement)"
    },
    "breadcrumb_integration": {
      "nav_breadcrumb_parity": true,
      "footer_breadcrumb": true,
      "description": "Footer category links align with breadcrumb trail"
    },
    "internal_link_equity": {
      "nav_link_weight": "high",
      "footer_link_weight": "medium",
      "description": "Category links in both nav and footer maximize link equity distribution"
    }
  },
  "implementation_notes": {
    "method": "WordPress Appearance > Menus + Widget Areas (Manual)",
    "alternative": "wpcom-mcp site-editor-context + navigation block updates (API)",
    "steps": [
      "1. Log in to WordPress admin dashboard",
      "2. Go to Appearance > Menus",
      "3. Create new menu 'Main Navigation' with 7 items (Home, 5 categories, Search)",
      "4. Assign menu to 'Primary Menu' location",
      "5. Go to Appearance > Widgets",
      "6. Add custom menu/HTML widgets to Footer area",
      "7. Test mobile responsiveness (hamburger at 768px)",
      "8. Verify all links return 200 (no broken links)",
      "9. Test keyboard navigation (tab through menu items)"
    ]
  },
  "verification": {
