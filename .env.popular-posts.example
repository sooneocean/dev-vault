# YOLO LAB Popular Posts Fetcher - Environment Configuration
#
# Copy this file to .env or set these environment variables
# before running: node scripts/fetch-popular-posts.js

# WordPress.com OAuth2 Token (required for API access)
# Get your token from: https://wordpress.com/me/account/security
# Format: Usually starts with "eyJ0e..." or similar
WORDPRESS_DOT_COM_TOKEN=your_valid_oauth2_token_here

# Alternative token variable name (if using WP_COM_TOKEN instead)
# WP_COM_TOKEN=your_valid_oauth2_token_here

# YOLO LAB Site ID (WordPress.com site identifier)
YOLO_LAB_SITE_ID=133512998

# Cache validity (in days)
# How long to keep cached popular posts before requiring fresh API data
CACHE_MAX_AGE_DAYS=7

# Optional: Debug mode (set to 1 to enable verbose logging)
# DEBUG=1
