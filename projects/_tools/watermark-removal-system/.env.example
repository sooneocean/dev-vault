# Watermark Removal System - Docker Environment Configuration
# Copy to .env and customize for your environment

# ComfyUI Backend Configuration
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188

# GPU Configuration
# Use GPU index: 0, 1, 2, ... or -1 for CPU only
GPU_INDEX=0

# Model Cache Directory
# Downloads and caches ML models here
MODELS_CACHE=./models

# Service Ports
WATERMARK_REMOVAL_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana Authentication
GRAFANA_PASSWORD=admin

# Configuration File Path
# Override with --config argument
CONFIG_FILE=./config/docker.yaml

# Logging Level
LOG_LEVEL=INFO

# Memory Limits
# Adjust based on available system memory
COMFYUI_MEMORY_GB=4

# Performance Tuning
# Batch size for parallel inpainting
BATCH_SIZE=4

# Timeout for inpainting jobs (seconds)
INPAINT_TIMEOUT_SEC=300

# Optional: Model-specific configuration
# Uncomment if using custom model paths
# YOLO_MODEL_PATH=./models/yolov8n.pt
# INPAINT_MODEL=flux-dev

# Optional: Custom network configuration
# DOCKER_NETWORK=production-network

# Optional: Authentication tokens (use Docker secrets in production)
# COMFYUI_API_KEY=
# WEBHOOK_TOKEN=
