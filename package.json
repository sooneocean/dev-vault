{
  "name": "dev-vault",
  "version": "1.0.0",
  "type": "module",
  "description": "Claude Code DevVault - PARA-style knowledge management and automation",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:proposal": "jest .claude/lib/proposal-engine.test.js",
    "test:proposal-integration": "jest .claude/lib/proposal-engine.integration.test.js --forceExit",
    "optimize:scan": "node scripts/site-optimizer.js --site yololab --type image-alt --phase scan",
    "optimize:scan-sample": "node scripts/site-optimizer.js --site yololab --type image-alt --phase scan --sample 10",
    "optimize:featured": "node scripts/site-optimizer.js --site yololab --type image-alt --phase apply-featured",
    "optimize:inline": "node scripts/site-optimizer.js --site yololab --type image-alt --phase apply-inline",
    "optimize:report": "node scripts/site-optimizer.js --site yololab --type image-alt --phase report",
    "optimize:rollback": "node scripts/site-optimizer.js --site yololab --type image-alt --phase rollback --target all"
  },
  "keywords": [
    "obsidian",
    "vault",
    "knowledge-management",
    "automation"
  ],
  "author": "sooneocean",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0"
  }
}
